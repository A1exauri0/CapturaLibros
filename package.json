{
  "name": "captura-libros",
  "version": "1.0.0",
  "description": "Aplicación de captura y recorte de libros en formato PDF",
  "main": "principal.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "appId": "com.capturalibros.app",
    "productName": "CapturaLibros",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "dir",
      "icon": "assets/libros.png"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!pdfs/**/*"
    ]
  }
}
